rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function isAdmin() {
      return signedIn() && request.auth.token.email == 'marcelreifenstein@yahoo.com';
    }
    function eventOpen(eventId) {
      let event = get(/databases/$(database)/documents/events/$(eventId)).data;
      return event.enabled == true
        && request.time >= event.startAt
        && request.time <= event.endAt;
    }

    match /events/{eventId} {
      allow read: if true;
      allow write: if isAdmin();

      match /wishes/{wishId} {
        allow get, list: if isAdmin() || resource.data.hidden == false;
        allow create: if signedIn()
          && eventOpen(eventId)
          && request.resource.data.keys().hasOnly(['artist','title','priority','likesCount','hidden','status','createdAt'])
          && request.resource.data.artist is string
          && request.resource.data.title is string
          && request.resource.data.priority >= 1
          && request.resource.data.priority <= 10
          && request.resource.data.likesCount == 0
          && request.resource.data.hidden == false
          && request.resource.data.status == 'open';
        allow update: if isAdmin() || (
          signedIn()
          && eventOpen(eventId)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likesCount'])
          && request.resource.data.likesCount == resource.data.likesCount + 1
          && !exists(/databases/$(database)/documents/events/$(eventId)/wishes/$(wishId)/likes/$(request.auth.uid))
          && existsAfter(/databases/$(database)/documents/events/$(eventId)/wishes/$(wishId)/likes/$(request.auth.uid))
        );
        allow delete: if isAdmin();

        match /likes/{uid} {
          allow create: if signedIn()
            && eventOpen(eventId)
            && request.auth.uid == uid
            && request.resource.data.keys().hasOnly(['createdAt']);
          allow read, delete: if isAdmin();
          allow update: if false;
        }
      }

      match /wishPrivate/{wishId} {
        allow read: if isAdmin() || (signedIn() && resource.data.ownerUid == request.auth.uid);
        allow create: if signedIn()
          && eventOpen(eventId)
          && request.resource.data.ownerUid == request.auth.uid
          && request.resource.data.keys().hasOnly(['ownerUid','firstName','artistNormalized','titleNormalized','createdAt']);
        allow update, delete: if isAdmin();
      }
    }
  }
}
