import { initializeApp } from 'https://www.gstatic.com/firebasejs/11.10.0/firebase-app.js';
import { getAuth } from 'https://www.gstatic.com/firebasejs/11.10.0/firebase-auth.js';
import { getFirestore } from 'https://www.gstatic.com/firebasejs/11.10.0/firebase-firestore.js';

const config = window.DJ_REIFI_CONFIG?.firebase || {};
export const isFirebaseConfigured = Boolean(
  config.apiKey &&
  config.projectId &&
  !Object.values(config).some((value) => String(value).includes('HIER_EINTRAGEN'))
);

let app = null;
let auth = null;
let db = null;

if (isFirebaseConfigured) {
  app = initializeApp(config);
  auth = getAuth(app);
  db = getFirestore(app);
}

export { app, auth, db };
export const ADMIN_EMAIL = (window.DJ_REIFI_CONFIG?.adminEmail || '').toLowerCase();
export const normalizeCode = (value) => String(value || '').trim().toUpperCase().replace(/[^A-Z0-9ÄÖÜ_-]/g, '');
export const normalizeText = (value) => String(value || '').trim().toLocaleLowerCase('de-DE').replace(/\s+/g, ' ');
