import { auth, db, isFirebaseConfigured, ADMIN_EMAIL, normalizeCode } from './firebase-common.js';
import {
  signInWithEmailAndPassword, signOut, onAuthStateChanged
} from 'https://www.gstatic.com/firebasejs/11.10.0/firebase-auth.js';
import {
  collection, doc, getDocs, getDoc, setDoc, deleteDoc, updateDoc,
  query, orderBy, onSnapshot, Timestamp, writeBatch
} from 'https://www.gstatic.com/firebasejs/11.10.0/firebase-firestore.js';

const warning = document.querySelector('#firebase-warning');
const loginForm = document.querySelector('#login-form');
const loginStatus = document.querySelector('#login-status');
const adminApp = document.querySelector('#admin-app');
const logoutButton = document.querySelector('#logout');
const eventForm = document.querySelector('#event-form');
const eventFormStatus = document.querySelector('#event-form-status');
const eventList = document.querySelector('#event-list');
const adminEmpty = document.querySelector('#admin-empty');
const eventDetail = document.querySelector('#event-detail');
const detailTitle = document.querySelector('#detail-title');
const detailMeta = document.querySelector('#detail-meta');
const adminWishes = document.querySelector('#admin-wishes');
const adminNoWishes = document.querySelector('#admin-no-wishes');
const deleteEventButton = document.querySelector('#delete-event');
let currentEventId = null;
let unsubscribeEvents = null;
let unsubscribeWishes = null;

if (!isFirebaseConfigured) {
  warning.classList.remove('hidden');
  loginForm.querySelector('button').disabled = true;
}

const setStatus = (element, message, type = '') => {
  element.textContent = message;
  element.className = `form-status ${type}`.trim();
};
const formatDate = (timestamp) => timestamp?.toDate?.().toLocaleString('de-DE', { dateStyle: 'medium', timeStyle: 'short' }) || '–';
const escapeHtml = (value) => String(value || '').replace(/[&<>'"]/g, (character) => ({ '&':'&amp;', '<':'&lt;', '>':'&gt;', "'":'&#39;', '"':'&quot;' }[character]));

if (isFirebaseConfigured) loginForm?.addEventListener('submit', async (event) => {
  event.preventDefault();
  const email = document.querySelector('#admin-email').value.trim();
  const password = document.querySelector('#admin-password').value;
  setStatus(loginStatus, 'Anmeldung läuft …');
  try {
    await signInWithEmailAndPassword(auth, email, password);
  } catch (error) {
    setStatus(loginStatus, 'Anmeldung fehlgeschlagen. Prüfe E-Mail-Adresse und Passwort.', 'error');
  }
});

if (isFirebaseConfigured) logoutButton?.addEventListener('click', () => signOut(auth));

if (isFirebaseConfigured) onAuthStateChanged(auth, (user) => {
  const allowed = user && user.email?.toLowerCase() === ADMIN_EMAIL;
  loginForm.classList.toggle('hidden', allowed);
  adminApp.classList.toggle('hidden', !allowed);
  logoutButton.classList.toggle('hidden', !allowed);
  if (allowed) watchEvents();
  else {
    unsubscribeEvents?.();
    unsubscribeWishes?.();
  }
});

function watchEvents() {
  unsubscribeEvents?.();
  unsubscribeEvents = onSnapshot(query(collection(db, 'events'), orderBy('startAt', 'desc')), (snapshot) => {
    eventList.innerHTML = '';
    snapshot.docs.forEach((entry) => {
      const data = entry.data();
      const button = document.createElement('button');
      button.type = 'button';
      button.className = `event-button ${entry.id === currentEventId ? 'active' : ''}`;
      button.innerHTML = `<strong>${escapeHtml(data.name)}</strong><br><span class="muted">${escapeHtml(entry.id)} · ${formatDate(data.startAt)}</span>`;
      button.addEventListener('click', () => selectEvent(entry.id, data));
      eventList.appendChild(button);
    });
  });
}

eventForm?.addEventListener('submit', async (event) => {
  event.preventDefault();
  const code = normalizeCode(document.querySelector('#event-code-admin').value);
  const name = document.querySelector('#event-name').value.trim();
  const startValue = document.querySelector('#event-start').value;
  const endValue = document.querySelector('#event-end').value;
  if (!code || !name || !startValue || !endValue) return;
  const start = new Date(startValue);
  const end = new Date(endValue);
  if (end <= start) return setStatus(eventFormStatus, 'Das Ende muss nach dem Beginn liegen.', 'error');

  try {
    await setDoc(doc(db, 'events', code), {
      name,
      enabled: document.querySelector('#event-enabled').checked,
      startAt: Timestamp.fromDate(start),
      endAt: Timestamp.fromDate(end),
      updatedAt: Timestamp.now()
    }, { merge: true });
    eventForm.reset();
    document.querySelector('#event-enabled').checked = true;
    setStatus(eventFormStatus, 'Veranstaltung wurde gespeichert.', 'success');
  } catch (error) {
    setStatus(eventFormStatus, 'Veranstaltung konnte nicht gespeichert werden.', 'error');
  }
});

async function selectEvent(id, data) {
  currentEventId = id;
  document.querySelectorAll('.event-button').forEach((button) => button.classList.remove('active'));
  [...document.querySelectorAll('.event-button')].find((button) => button.textContent.includes(id))?.classList.add('active');
  adminEmpty.classList.add('hidden');
  eventDetail.classList.remove('hidden');
  detailTitle.textContent = data.name;
  detailMeta.textContent = `Code: ${id} · ${formatDate(data.startAt)} bis ${formatDate(data.endAt)} · ${data.enabled ? 'aktiviert' : 'deaktiviert'}`;
  watchAdminWishes();
}

function watchAdminWishes() {
  unsubscribeWishes?.();
  unsubscribeWishes = onSnapshot(query(collection(db, 'events', currentEventId, 'wishes'), orderBy('createdAt', 'desc')), async (snapshot) => {
    adminWishes.innerHTML = '';
    const rows = await Promise.all(snapshot.docs.map(async (entry) => {
      const privateSnapshot = await getDoc(doc(db, 'events', currentEventId, 'wishPrivate', entry.id));
      return { id: entry.id, ...entry.data(), privateData: privateSnapshot.data() || {} };
    }));
    adminNoWishes.classList.toggle('hidden', rows.length > 0);
    rows.forEach((wish) => adminWishes.appendChild(renderAdminWish(wish)));
  });
}

function renderAdminWish(wish) {
  const row = document.createElement('article');
  row.className = 'admin-wish';
  const statusClass = wish.status === 'played' ? 'status-pill played' : 'status-pill';
  row.innerHTML = `
    <div>
      <h3>${escapeHtml(wish.artist)} – ${escapeHtml(wish.title)}</h3>
      <div class="muted">Vorname: <strong>${escapeHtml(wish.privateData.firstName || '–')}</strong> · Priorität ${wish.priority}/10 · ${wish.likesCount || 0} Likes</div>
      <span class="${statusClass}">${wish.status === 'played' ? 'gespielt' : wish.hidden ? 'ausgeblendet' : 'offen'}</span>
    </div>
    <div class="admin-actions">
      <button class="btn btn-secondary btn-small" data-action="played">${wish.status === 'played' ? 'Als offen markieren' : 'Als gespielt markieren'}</button>
      <button class="btn btn-secondary btn-small" data-action="hidden">${wish.hidden ? 'Einblenden' : 'Ausblenden'}</button>
      <button class="btn btn-danger btn-small" data-action="delete">Löschen</button>
    </div>`;
  row.querySelector('[data-action="played"]').addEventListener('click', () => updateDoc(doc(db, 'events', currentEventId, 'wishes', wish.id), { status: wish.status === 'played' ? 'open' : 'played' }));
  row.querySelector('[data-action="hidden"]').addEventListener('click', () => updateDoc(doc(db, 'events', currentEventId, 'wishes', wish.id), { hidden: !wish.hidden }));
  row.querySelector('[data-action="delete"]').addEventListener('click', () => deleteWish(wish.id));
  return row;
}

async function deleteWish(id) {
  if (!confirm('Diesen Musikwunsch wirklich löschen?')) return;
  const batch = writeBatch(db);
  batch.delete(doc(db, 'events', currentEventId, 'wishes', id));
  batch.delete(doc(db, 'events', currentEventId, 'wishPrivate', id));
  await batch.commit();
}

deleteEventButton?.addEventListener('click', async () => {
  if (!currentEventId || !confirm('Die Veranstaltung und alle Musikwünsche wirklich löschen?')) return;
  deleteEventButton.disabled = true;
  try {
    const wishesSnapshot = await getDocs(collection(db, 'events', currentEventId, 'wishes'));
    for (const wishEntry of wishesSnapshot.docs) {
      const likesSnapshot = await getDocs(collection(db, 'events', currentEventId, 'wishes', wishEntry.id, 'likes'));
      const batch = writeBatch(db);
      likesSnapshot.docs.forEach((likeEntry) => batch.delete(likeEntry.ref));
      batch.delete(wishEntry.ref);
      batch.delete(doc(db, 'events', currentEventId, 'wishPrivate', wishEntry.id));
      await batch.commit();
    }
    const privateSnapshot = await getDocs(collection(db, 'events', currentEventId, 'wishPrivate'));
    for (const privateEntry of privateSnapshot.docs) await deleteDoc(privateEntry.ref);
    await deleteDoc(doc(db, 'events', currentEventId));
    currentEventId = null;
    eventDetail.classList.add('hidden');
    adminEmpty.classList.remove('hidden');
  } finally {
    deleteEventButton.disabled = false;
  }
});
