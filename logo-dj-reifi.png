(() => {
  const menuButton = document.querySelector('[data-menu-button]');
  const navigation = document.querySelector('[data-navigation]');

  if (menuButton && navigation) {
    menuButton.addEventListener('click', () => {
      const open = navigation.classList.toggle('open');
      menuButton.setAttribute('aria-expanded', String(open));
    });
  }

  document.querySelectorAll('[data-navigation] a').forEach((link) => {
    link.addEventListener('click', () => {
      navigation?.classList.remove('open');
      menuButton?.setAttribute('aria-expanded', 'false');
    });
  });

  const form = document.querySelector('#inquiry-form');
  if (!form) return;

  const serviceRadios = [...form.querySelectorAll('input[name="Leistungsart"]')];
  const djFields = form.querySelector('[data-service-fields="dj"]');
  const rentalFields = form.querySelector('[data-service-fields="rental"]');
  const contactPreference = form.querySelector('#kontaktweg');
  const phoneGroup = form.querySelector('[data-phone-group]');
  const status = form.querySelector('[data-form-status]');
  const submitButton = form.querySelector('button[type="submit"]');

  const toggleServiceFields = () => {
    const selected = serviceRadios.find((radio) => radio.checked)?.value;
    djFields?.classList.toggle('is-visible', selected === 'DJ-Dienstleistung');
    rentalFields?.classList.toggle('is-visible', selected === 'Technikmiete');

    djFields?.querySelectorAll('[data-required-when-visible]').forEach((field) => {
      field.required = selected === 'DJ-Dienstleistung';
    });
    rentalFields?.querySelectorAll('[data-required-when-visible]').forEach((field) => {
      field.required = selected === 'Technikmiete';
    });
  };

  const togglePhone = () => {
    const needsPhone = contactPreference?.value === 'WhatsApp';
    phoneGroup?.classList.toggle('hidden', !needsPhone);
    const phone = phoneGroup?.querySelector('input');
    if (phone) phone.required = needsPhone;
  };

  serviceRadios.forEach((radio) => radio.addEventListener('change', toggleServiceFields));
  contactPreference?.addEventListener('change', togglePhone);
  toggleServiceFields();
  togglePhone();

  const serializeForEmail = (data) => {
    const lines = [];
    for (const [key, value] of data.entries()) {
      if (key.startsWith('_') || !String(value).trim()) continue;
      lines.push(`${key}: ${value}`);
    }
    return lines.join('\n');
  };

  form.addEventListener('submit', async (event) => {
    event.preventDefault();
    if (!form.reportValidity()) return;

    const config = window.DJ_REIFI_CONFIG || {};
    const endpoint = (config.formspreeEndpoint || '').trim();
    const formData = new FormData(form);
    formData.set('_subject', `Neue Anfrage: ${formData.get('Leistungsart') || 'DJ Reifi'}`);

    submitButton.disabled = true;
    status.className = 'form-status';
    status.textContent = 'Anfrage wird vorbereitet …';

    if (!endpoint) {
      const subject = encodeURIComponent(`Anfrage über djreifi.de – ${formData.get('Leistungsart') || ''}`);
      const body = encodeURIComponent(serializeForEmail(formData));
      const recipient = encodeURIComponent(config.contactEmail || 'marcelreifenstein@yahoo.com');
      window.location.href = `mailto:${recipient}?subject=${subject}&body=${body}`;
      status.textContent = 'Dein E-Mail-Programm wurde geöffnet. Bitte sende die vorbereitete Nachricht dort ab.';
      status.classList.add('success');
      submitButton.disabled = false;
      return;
    }

    try {
      const response = await fetch(endpoint, {
        method: 'POST',
        body: formData,
        headers: { Accept: 'application/json' }
      });

      if (!response.ok) throw new Error('Formularversand fehlgeschlagen');
      form.reset();
      toggleServiceFields();
      togglePhone();
      status.textContent = 'Vielen Dank. Deine Anfrage wurde erfolgreich versendet.';
      status.classList.add('success');
    } catch (error) {
      status.textContent = 'Die Anfrage konnte nicht versendet werden. Bitte nutze alternativ die direkte E-Mail-Adresse.';
      status.classList.add('error');
    } finally {
      submitButton.disabled = false;
    }
  });
})();
